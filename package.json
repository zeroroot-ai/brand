{
  "name": "@zeroroot-ai/brand",
  "version": "0.1.0",
  "description": "ZeroRoot brand design tokens, CSS custom properties, and theme utilities",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./globals.css": "./dist/globals.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test src/__tests__/tokens.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/zeroroot-ai/brand.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
